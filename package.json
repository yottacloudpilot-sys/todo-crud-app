{
  "name": "todo-crud-app",
  "version": "1.0.0",
  "description": "A full-stack Todo CRUD application",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "node --experimental-sqlite node_modules/jest/bin/jest.js --runInBand --forceExit"
  },
  "dependencies": {
    "cors": "2.8.5",
    "express": "4.18.2",
    "typescript": "5.3.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.11",
    "@types/node": "22.10.0",
    "@types/supertest": "6.0.2",
    "fast-check": "3.15.0",
    "jest": "29.7.0",
    "supertest": "6.3.4",
    "ts-jest": "29.1.2",
    "ts-node-dev": "2.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
    }
  }
}
